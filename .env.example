# Clave secreta para firmar sesiones/CSRF de la web.
# En producción GENERA una aleatoria de >=32 bytes, p. ej.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# y NO la subas al repo.
SECRET_KEY=cambia-esto-por-una-clave-aleatoria

# Activa el modo debug SOLO en desarrollo local (nunca en producción:
# el debugger de Werkzeug permite ejecución remota de código).
FLASK_DEBUG=0

# Puerto de la web (por defecto 5000).
PORT=5000
